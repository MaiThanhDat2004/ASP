@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký — TaskFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
            body { font-family: 'Plus Jakarta Sans', sans-serif; min-height: 100vh; display: flex; background: #0f172a; overflow: hidden; }

            /* LEFT PANEL */
            .left-panel { flex: 1; display: flex; align-items: center; justify-content: center; padding: 48px 60px; position: relative; overflow: hidden; }
            .left-panel::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 20% 50%, rgba(99,102,241,0.25) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 80% 20%, rgba(139,92,246,0.18) 0%, transparent 55%), radial-gradient(ellipse 50% 50% at 60% 80%, rgba(16,185,129,0.1) 0%, transparent 50%); }
            .grid-pattern { position: absolute; inset: 0; background-image: linear-gradient(rgba(99,102,241,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.08) 1px, transparent 1px); background-size: 48px 48px; }
            .left-content { position: relative; z-index: 1; width: 100%; display: flex; align-items: center; gap: 48px; }
            .left-text { flex: 1; min-width: 0; }
            .brand-mark { display: flex; align-items: center; gap: 12px; margin-bottom: 48px; }
            .brand-icon { width: 42px; height: 42px; background: #6366f1; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; box-shadow: 0 0 30px rgba(99,102,241,0.4); }
            .brand-name { font-size: 20px; font-weight: 800; color: #fff; letter-spacing: -0.3px; }
            .brand-name span { color: #818cf8; }
            .hero-heading { font-size: 38px; font-weight: 800; color: #fff; line-height: 1.15; letter-spacing: -1px; margin-bottom: 14px; }
            .hero-heading em { font-style: normal; background: linear-gradient(135deg, #818cf8, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
            .hero-sub { font-size: 15px; color: #64748b; line-height: 1.65; margin-bottom: 36px; }
            .feature-list { display: flex; flex-direction: column; gap: 12px; }
            .feature-item { display: flex; align-items: center; gap: 12px; }
            .feature-dot { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
            .feature-dot.green  { background: rgba(16,185,129,0.15); color: #10b981; }
            .feature-dot.indigo { background: rgba(99,102,241,0.15); color: #6366f1; }
            .feature-dot.amber  { background: rgba(245,158,11,0.15); color: #f59e0b; }
            .feature-text { font-size: 14px; color: #94a3b8; font-weight: 500; }

            /* Floating cards */
            .floating-cards { display: flex; flex-direction: column; gap: 10px; flex-shrink: 0; opacity: 0.75; }
            .mini-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 10px 14px; width: 210px; backdrop-filter: blur(8px); }
            .mini-card-title { font-size: 12px; font-weight: 600; color: #e2e8f0; margin-bottom: 6px; }
            .mini-card-row { display: flex; align-items: center; justify-content: space-between; }
            .mini-badge { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 10px; }
            .mini-badge.done  { background: rgba(16,185,129,0.2); color: #34d399; }
            .mini-badge.doing { background: rgba(245,158,11,0.2); color: #fbbf24; }
            .mini-badge.todo  { background: rgba(148,163,184,0.2); color: #94a3b8; }
            .mini-avatar { width: 18px; height: 18px; border-radius: 4px; background: linear-gradient(135deg,#6366f1,#8b5cf6); font-size: 9px; font-weight: 700; color: white; display: flex; align-items: center; justify-content: center; }
            @@keyframes float-up { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
            .floating-cards { animation: float-up 4s ease-in-out infinite; }

            /* RIGHT PANEL */
            .right-panel { width: 500px; min-height: 100vh; background: #fff; display: flex; align-items: center; justify-content: center; padding: 40px 56px; flex-shrink: 0; box-shadow: -20px 0 60px rgba(0,0,0,0.15); overflow-y: auto; }
            .register-form-wrap { width: 100%; max-width: 380px; }
            .form-greeting { margin-bottom: 28px; }
            .form-greeting h1 { font-size: 24px; font-weight: 800; color: #0f172a; margin-bottom: 6px; letter-spacing: -0.5px; }
            .form-greeting p { font-size: 14px; color: #64748b; }

            .field-group { margin-bottom: 18px; }
            .field-label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #475569; margin-bottom: 7px; }
            .field-wrap { position: relative; }
            .field-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 15px; pointer-events: none; }
            .field-input { width: 100%; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 11px 14px 11px 38px; font-size: 14px; font-family: 'Plus Jakarta Sans', sans-serif; color: #0f172a; background: #f8fafc; transition: all .2s; outline: none; }
            .field-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); background: #fff; }
            .field-input::placeholder { color: #cbd5e1; }
            .password-toggle { position: absolute; right: 13px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 15px; padding: 0; }
            .password-toggle:hover { color: #6366f1; }

            .alert-error { background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px; padding: 12px 14px; color: #b91c1c; font-size: 13px; font-weight: 500; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; }

            .btn-register { width: 100%; background: #6366f1; color: white; border: none; border-radius: 10px; padding: 13px; font-size: 15px; font-weight: 700; font-family: 'Plus Jakarta Sans', sans-serif; cursor: pointer; transition: background .2s, transform .15s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 4px; }
            .btn-register:hover { background: #4f46e5; transform: translateY(-1px); }

            .divider { height: 1px; background: #f1f5f9; margin: 22px 0; }
            .login-link { text-align: center; font-size: 13.5px; color: #64748b; }
            .login-link a { color: #6366f1; font-weight: 700; text-decoration: none; }
            .login-link a:hover { text-decoration: underline; }
            .footer-text { text-align: center; font-size: 12px; color: #94a3b8; margin-top: 20px; }

            .pw-strength { height: 4px; border-radius: 99px; margin-top: 6px; background: #e2e8f0; transition: all .3s; }
            .pw-strength-label { font-size: 11px; margin-top: 3px; font-weight: 600; color: #94a3b8; }
            .strength-weak   { background: #ef4444; width: 33%; }
            .strength-medium { background: #f59e0b; width: 66%; }
            .strength-strong { background: #10b981; width: 100%; }

            @@media (max-width: 860px) { .left-panel { display: none; } .right-panel { width: 100%; } }
    </style>
</head>
<body>
    <!-- Left panel -->
    <div class="left-panel">
        <div class="grid-pattern"></div>
        <div class="left-content">
            <div class="left-text">
                <div class="brand-mark">
                    <div class="brand-icon">✓</div>
                    <div class="brand-name">Task<span>Flow</span></div>
                </div>
                <h1 class="hero-heading">
                    Bắt đầu hành trình<br>
                    <em>cùng nhóm của bạn</em>
                </h1>
                <p class="hero-sub">
                    Tạo tài khoản miễn phí, lập nhóm và bắt đầu quản lý công việc ngay hôm nay.
                </p>
                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-dot green"><i class="bi bi-people-fill"></i></div>
                        <span class="feature-text">Tạo nhóm và phân công việc linh hoạt</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-dot indigo"><i class="bi bi-graph-up"></i></div>
                        <span class="feature-text">Theo dõi tiến độ theo thời gian thực</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-dot amber"><i class="bi bi-shield-check"></i></div>
                        <span class="feature-text">Bảo mật tài khoản với mã hóa BCrypt</span>
                    </div>
                </div>
            </div>
            <div class="floating-cards">
                <div class="mini-card">
                    <div class="mini-card-title">Thiết kế UI Dashboard</div>
                    <div class="mini-card-row"><span class="mini-badge done">Done</span><div class="mini-avatar">A</div></div>
                </div>
                <div class="mini-card">
                    <div class="mini-card-title">API tích hợp báo cáo</div>
                    <div class="mini-card-row"><span class="mini-badge doing">Doing</span><div class="mini-avatar">B</div></div>
                </div>
                <div class="mini-card">
                    <div class="mini-card-title">Viết unit test module</div>
                    <div class="mini-card-row"><span class="mini-badge todo">ToDo</span><div class="mini-avatar">C</div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right panel -->
    <div class="right-panel">
        <div class="register-form-wrap">
            <div class="form-greeting">
                <h1>Tạo tài khoản mới 🚀</h1>
                <p>Điền thông tin để bắt đầu sử dụng TaskFlow</p>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-error">
                    <i class="bi bi-exclamation-circle-fill"></i>
                    @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="Register" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()

                <div class="field-group">
                    <label class="field-label">Họ và tên *</label>
                    <div class="field-wrap">
                        <i class="bi bi-person field-icon"></i>
                        <input type="text" name="fullName" class="field-input" placeholder="Nguyễn Văn A" required />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label">Email *</label>
                    <div class="field-wrap">
                        <i class="bi bi-envelope field-icon"></i>
                        <input type="email" name="email" class="field-input" placeholder="email@example.com" required />
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label">Mật khẩu *</label>
                    <div class="field-wrap">
                        <i class="bi bi-lock field-icon"></i>
                        <input type="password" name="password" id="passwordInput" class="field-input"
                               placeholder="••••••••" required oninput="checkStrength(this.value)" />
                        <button type="button" class="password-toggle" onclick="togglePw('passwordInput', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="pw-strength" id="pwStrengthBar"></div>
                    <div class="pw-strength-label" id="pwStrengthLabel"></div>
                </div>

                <div class="field-group">
                    <label class="field-label">Xác nhận mật khẩu *</label>
                    <div class="field-wrap">
                        <i class="bi bi-lock-fill field-icon"></i>
                        <input type="password" name="confirmPassword" id="confirmInput" class="field-input"
                               placeholder="••••••••" required oninput="checkMatch()" />
                        <button type="button" class="password-toggle" onclick="togglePw('confirmInput', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div id="matchMsg" style="font-size:11px; margin-top:3px; font-weight:600;"></div>
                </div>

                <button type="submit" class="btn-register">
                    <i class="bi bi-person-plus-fill"></i> Tạo tài khoản
                </button>
            </form>

            <div class="divider"></div>
            <div class="login-link">
                Đã có tài khoản? <a asp-action="Login" asp-controller="Account">Đăng nhập ngay</a>
            </div>
            <div class="footer-text">&copy; 2026 TaskFlow — Task Management System</div>
        </div>
    </div>

    <script>
            function togglePw(id, btn) {
                const input = document.getElementById(id);
                const icon = btn.querySelector('i');
                if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye-slash'; }
                else { input.type = 'password'; icon.className = 'bi bi-eye'; }
            }

            function checkStrength(val) {
                const bar = document.getElementById('pwStrengthBar');
                const label = document.getElementById('pwStrengthLabel');
                if (!val) { bar.className = 'pw-strength'; label.textContent = ''; return; }
                const strong = val.length >= 8 && /[A-Z]/.test(val) && /[0-9]/.test(val);
                const medium = val.length >= 6 && (/[A-Z]/.test(val) || /[0-9]/.test(val));
                if (strong)      { bar.className = 'pw-strength strength-strong'; label.textContent = '💪 Mạnh'; label.style.color = '#10b981'; }
                else if (medium) { bar.className = 'pw-strength strength-medium'; label.textContent = '⚠️ Trung bình'; label.style.color = '#f59e0b'; }
                else             { bar.className = 'pw-strength strength-weak';   label.textContent = '❌ Yếu'; label.style.color = '#ef4444'; }
            }

            function checkMatch() {
                const pw = document.getElementById('passwordInput').value;
                const cp = document.getElementById('confirmInput').value;
                const msg = document.getElementById('matchMsg');
                if (!cp) { msg.textContent = ''; return; }
                if (pw === cp) { msg.textContent = '✅ Khớp'; msg.style.color = '#10b981'; }
                else           { msg.textContent = '❌ Chưa khớp'; msg.style.color = '#ef4444'; }
            }
    </script>
</body>
</html>
