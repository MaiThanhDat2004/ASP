@model IEnumerable<TaskManagement.Web.Models.User>

@{
    ViewData["Title"] = "Quản lý thành viên";
    var taskCountDict = ViewBag.TaskCountDict as Dictionary<int, int> ?? new();
    var currentUserId = int.Parse(User.FindFirst("UserId")!.Value);
}

<style>
    .page-heading { font-size: 22px; font-weight: 800; color: #0f172a; margin: 0; }
    .page-sub     { font-size: 14px; color: #64748b; margin: 4px 0 0; }

    .section-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden; margin-bottom: 20px; }
    .section-header { padding: 16px 22px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
    .section-header h5 { font-size: 15px; font-weight: 700; margin: 0; }

    .user-table { width: 100%; border-collapse: collapse; }
    .user-table th { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #94a3b8; padding: 12px 20px; border-bottom: 1px solid #f1f5f9; text-align: left; background: #f8fafc; }
    .user-table td { padding: 14px 20px; border-bottom: 1px solid #f8fafc; font-size: 13.5px; vertical-align: middle; }
    .user-table tr:last-child td { border-bottom: none; }
    .user-table tr:hover td { background: #fafafe; }

    .user-avatar { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #818cf8); color: white; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .user-avatar.admin { background: linear-gradient(135deg, #f59e0b, #fbbf24); }

    .role-admin { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 700; }
    .role-user  { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 700; }

    .btn-edit-sm   { background: #f5f3ff; color: #6d28d9; border: 1px solid #ddd6fe; border-radius: 7px; padding: 6px 10px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif; display: inline-flex; align-items: center; gap: 4px; text-decoration: none; }
    .btn-delete-sm { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; border-radius: 7px; padding: 6px 10px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif; display: inline-flex; align-items: center; gap: 4px; }
    .btn-edit-sm:hover   { background: #ede9fe; }
    .btn-delete-sm:hover { background: #fee2e2; }

    .field-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: #475569; margin-bottom: 6px; display: block; }
    .field-input { width: 100%; border: 1px solid #e2e8f0; border-radius: 9px; padding: 9px 13px; font-size: 13.5px; font-family: 'Plus Jakarta Sans', sans-serif; outline: none; background: #f8fafc; }
    .field-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); background: #fff; }
    .field-select { width: 100%; border: 1px solid #e2e8f0; border-radius: 9px; padding: 9px 13px; font-size: 13.5px; font-family: 'Plus Jakarta Sans', sans-serif; outline: none; background: #f8fafc; }

    .btn-primary-custom { background: #6366f1; color: white; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13.5px; font-weight: 700; font-family: 'Plus Jakarta Sans', sans-serif; display: inline-flex; align-items: center; gap: 6px; cursor: pointer; }
    .btn-primary-custom:hover { background: #4f46e5; }

    .modal-backdrop-custom { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000; align-items: center; justify-content: center; }
    .modal-backdrop-custom.show { display: flex; }
    .modal-box { background: #fff; border-radius: 16px; padding: 28px; width: 100%; max-width: 460px; box-shadow: 0 20px 60px rgba(0,0,0,0.15); }
    .modal-title { font-size: 18px; font-weight: 800; margin-bottom: 20px; color: #0f172a; }
    .modal-footer-custom { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
    .btn-cancel { background: #f1f5f9; color: #475569; border: none; border-radius: 8px; padding: 10px 18px; font-size: 13.5px; font-weight: 600; cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif; }

    .alert-success-custom { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; border-radius: 10px; padding: 12px 16px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; margin-bottom: 20px; }
    .alert-error-custom   { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; border-radius: 10px; padding: 12px 16px; font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; margin-bottom: 20px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-heading">Quản lý thành viên</h1>
        <p class="page-sub">@Model.Count() tài khoản trong hệ thống</p>
    </div>
    <button class="btn-primary-custom" onclick="showCreateModal()">
        <i class="bi bi-person-plus"></i> Thêm thành viên
    </button>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-custom"><i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error-custom"><i class="bi bi-exclamation-circle-fill"></i> @TempData["ErrorMessage"]</div>
}

<!-- Danh sách user -->
<div class="section-card">
    <div class="section-header">
        <h5><i class="bi bi-people me-2" style="color:#6366f1;"></i>Danh sách tài khoản</h5>
    </div>
    <table class="user-table">
        <thead>
            <tr>
                <th>Thành viên</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Công việc được giao</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                var taskCount = taskCountDict.ContainsKey(u.UserId) ? taskCountDict[u.UserId] : 0;
                var uIdStr = u.UserId.ToString();
                var uFullName = u.FullName ?? "";
                var uEmail = u.Email ?? "";
                var uRole = u.Role ?? "User";
                var isCurrentUser = u.UserId == currentUserId;

                <tr>
                    <td>
                        <div style="display:flex; align-items:center; gap:10px;">
                            <div class="user-avatar @(uRole == "Admin" ? "admin" : "")">
                                @(uFullName.Length > 0 ? uFullName.Substring(0, 1).ToUpper() : "?")
                            </div>
                            <div>
                                <div style="font-weight:700;">@uFullName</div>
                                @if (isCurrentUser) { <div style="font-size:11px; color:#6366f1;">(Bạn)</div> }
                            </div>
                        </div>
                    </td>
                    <td style="color:#64748b;">@uEmail</td>
                    <td>
                        @if (uRole == "Admin") { <span class="role-admin"><i class="bi bi-shield-check me-1"></i>Admin</span> }
                        else { <span class="role-user"><i class="bi bi-person me-1"></i>User</span> }
                    </td>
                    <td>
                        <span style="font-weight:700; color:#6366f1;">@taskCount</span>
                        <span style="color:#94a3b8; font-size:12px;"> công việc</span>
                    </td>
                    <td>
                        <div style="display:flex; gap:6px;">
                            <button class="btn-edit-sm" onclick="showEditModal('@uIdStr', '@uFullName.Replace("'", "\\'")' , '@uRole')">
                                <i class="bi bi-pencil"></i> Sửa
                            </button>
                            @if (!isCurrentUser)
                            {
                                <form asp-action="DeleteUser" asp-controller="Admin" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@uIdStr" />
                                    <button type="submit" class="btn-delete-sm" onclick="return confirm('Xóa tài khoản @uFullName?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Tạo user -->
<div class="modal-backdrop-custom" id="createModal">
    <div class="modal-box">
        <div class="modal-title"><i class="bi bi-person-plus me-2" style="color:#6366f1;"></i>Thêm thành viên mới</div>
        <form asp-action="CreateUser" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="field-label">Họ tên</label>
                <input type="text" name="fullName" class="field-input" placeholder="Nguyễn Văn A" required />
            </div>
            <div class="mb-3">
                <label class="field-label">Email</label>
                <input type="email" name="email" class="field-input" placeholder="nguyenvana@email.com" required />
            </div>
            <div class="mb-3">
                <label class="field-label">Mật khẩu</label>
                <input type="password" name="password" class="field-input" placeholder="••••••••" required />
            </div>
            <div class="mb-3">
                <label class="field-label">Vai trò</label>
                <select name="role" class="field-select">
                    <option value="User">👤 User</option>
                    <option value="Admin">🛡️ Admin (Quản trị hệ thống)</option>
                </select>
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn-cancel" onclick="hideCreateModal()">Hủy</button>
                <button type="submit" class="btn-primary-custom"><i class="bi bi-person-check"></i> Tạo tài khoản</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Sửa user -->
<div class="modal-backdrop-custom" id="editModal">
    <div class="modal-box">
        <div class="modal-title"><i class="bi bi-pencil me-2" style="color:#6366f1;"></i>Chỉnh sửa tài khoản</div>
        <form asp-action="EditUser" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" id="editUserId" />
            <div class="mb-3">
                <label class="field-label">Họ tên</label>
                <input type="text" name="fullName" id="editFullName" class="field-input" required />
            </div>
            <div class="mb-3">
                <label class="field-label">Vai trò</label>
                <select name="role" id="editRole" class="field-select">
                    <option value="User">👤 User</option>
                    <option value="Admin">🛡️ Admin (Quản trị hệ thống)</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="field-label">Mật khẩu mới (để trống nếu không đổi)</label>
                <input type="password" name="newPassword" class="field-input" placeholder="••••••••" />
            </div>
            <div class="modal-footer-custom">
                <button type="button" class="btn-cancel" onclick="hideEditModal()">Hủy</button>
                <button type="submit" class="btn-primary-custom"><i class="bi bi-check-circle"></i> Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

<script>
    function showCreateModal() {
        document.getElementById('createModal').classList.add('show');
    }
    function hideCreateModal() {
        document.getElementById('createModal').classList.remove('show');
    }
    function showEditModal(id, fullName, role) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editFullName').value = fullName;
        document.getElementById('editRole').value = role;
        document.getElementById('editModal').classList.add('show');
    }
    function hideEditModal() {
        document.getElementById('editModal').classList.remove('show');
    }
    // Đóng modal khi click bên ngoài
    document.getElementById('createModal').addEventListener('click', function(e) {
        if (e.target === this) hideCreateModal();
    });
    document.getElementById('editModal').addEventListener('click', function(e) {
        if (e.target === this) hideEditModal();
    });
</script>
