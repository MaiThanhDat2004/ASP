                        </td>
                        <td style="text-align:center;">
                            <a asp-action="Details" asp-controller="Tasks" asp-route-id="@t.TaskId" class="btn-view">
                                <i class="bi bi-eye"></i> Xem
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleDone() {
        const content = document.getElementById('doneSectionContent');
        const chevron = document.getElementById('doneChevron');
        const isHidden = content.style.display === 'none';
        content.style.display = isHidden ? 'block' : 'none';
        chevron.className = isHidden ? 'bi bi-chevron-up' : 'bi bi-chevron-down';
    }
</script>