@model TaskManagement.Web.Models.TaskItem

@{
    ViewData["Title"] = "Xóa công việc";

    var statusCls = Model.Status switch
    {
        "ToDo" => "status-todo",
        "Doing" => "status-doing",
        "Done" => "status-done",
        _ => "status-todo"
    };
}

<style>
    .delete-wrapper {
        max-width: 600px;
        margin: 0 auto;
    }

    .delete-card {
        background: #fff;
        border: 1px solid #fecaca;
        border-radius: 16px;
        overflow: hidden;
    }

    .delete-header {
        padding: 24px 28px 20px;
        border-bottom: 1px solid #fee2e2;
        background: #fef2f2;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .delete-icon {
        width: 48px;
        height: 48px;
        background: rgba(239,68,68,0.12);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: #ef4444;
        flex-shrink: 0;
    }

    .delete-title {
        font-size: 18px;
        font-weight: 800;
        color: #991b1b;
        margin: 0;
    }

    .delete-subtitle {
        font-size: 13px;
        color: #b91c1c;
        margin: 3px 0 0;
        opacity: .8;
    }

    .delete-body {
        padding: 24px 28px;
    }

    .task-preview {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 18px 20px;
        margin-bottom: 24px;
    }

    .preview-row {
        display: flex;
        gap: 8px;
        align-items: flex-start;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .preview-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

    .preview-key {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: .4px;
        min-width: 110px;
        flex-shrink: 0;
        padding-top: 1px;
    }

    .preview-value {
        font-size: 14px;
        color: #0f172a;
        font-weight: 500;
    }

        .preview-value.muted {
            color: #94a3b8;
            font-weight: 400;
        }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }

        .status-pill::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

    .status-todo {
        background: #f1f5f9;
        color: #475569;
    }

        .status-todo::before {
            background: #94a3b8;
        }

    .status-doing {
        background: #fffbeb;
        color: #92400e;
    }

        .status-doing::before {
            background: #f59e0b;
        }

    .status-done {
        background: #ecfdf5;
        color: #065f46;
    }

        .status-done::before {
            background: #10b981;
        }

    .warning-box {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 13px;
        color: #92400e;
        font-weight: 500;
        margin-bottom: 24px;
    }

    .btn-confirm-delete {
        background: #ef4444;
        color: white;
        border: none;
        border-radius: 9px;
        padding: 11px 24px;
        font-size: 14px;
        font-weight: 700;
        font-family: 'Plus Jakarta Sans', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        transition: background .2s, transform .15s;
    }

        .btn-confirm-delete:hover {
            background: #dc2626;
            transform: translateY(-1px);
        }

    .btn-cancel {
        background: transparent;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        padding: 11px 22px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: all .2s;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            border-color: #94a3b8;
            color: #0f172a;
        }
</style>

<div class="delete-wrapper">
    <div class="delete-card">
        <div class="delete-header">
            <div class="delete-icon"><i class="bi bi-trash3-fill"></i></div>
            <div>
                <div class="delete-title">Xác nhận xóa công việc</div>
                <div class="delete-subtitle">Hành động này không thể hoàn tác</div>
            </div>
        </div>

        <div class="delete-body">
            <div class="warning-box">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:16px; flex-shrink:0;"></i>
                Bạn đang chuẩn bị xóa vĩnh viễn công việc này. Vui lòng kiểm tra lại thông tin trước khi xác nhận.
            </div>

            <div class="task-preview">
                <div class="preview-row">
                    <span class="preview-key">Tiêu đề</span>
                    <span class="preview-value">@Model.Title</span>
                </div>
                <div class="preview-row">
                    <span class="preview-key">Mô tả</span>
                    <span class="preview-value @(string.IsNullOrWhiteSpace(Model.Description) ? "muted" : "")">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả" : Model.Description)
                    </span>
                </div>
                <div class="preview-row">
                    <span class="preview-key">Trạng thái</span>
                    <span class="preview-value">
                        <span class="status-pill @statusCls">@Model.Status</span>
                    </span>
                </div>
                <div class="preview-row">
                    <span class="preview-key">Ưu tiên</span>
                    <span class="preview-value">@Model.Priority</span>
                </div>
                <div class="preview-row">
                    <span class="preview-key">Người tạo</span>
                    <span class="preview-value">@Model.CreatedBy</span>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="TaskId" />
                <div class="d-flex gap-3">
                    <button type="submit" class="btn-confirm-delete">
                        <i class="bi bi-trash3"></i> Xác nhận xóa
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="bi bi-x-lg"></i> Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
