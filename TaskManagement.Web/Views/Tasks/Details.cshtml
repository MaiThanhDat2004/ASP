@model TaskManagement.Web.Models.TaskItem

@{
    ViewData["Title"] = "Chi tiết công việc";

    var statusCls = Model.Status switch
    {
        "ToDo" => "status-todo",
        "Doing" => "status-doing",
        "Done" => "status-done",
        _ => "status-todo"
    };
    var statusColor = Model.Status switch
    {
        "ToDo" => "#94a3b8",
        "Doing" => "#f59e0b",
        "Done" => "#10b981",
        _ => "#94a3b8"
    };
    var priorityColor = Model.Priority switch
    {
        "Low" => "#06b6d4",
        "Medium" => "#3b82f6",
        "High" => "#ef4444",
        _ => "#94a3b8"
    };
    var isOverdue = Model.Deadline < DateTime.Now && Model.Status != "Done";
}

<style>
    .detail-wrapper {
        max-width: 820px;
        margin: 0 auto;
    }

    .detail-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        overflow: hidden;
    }

    .detail-header {
        padding: 24px 28px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

    .detail-title {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 6px;
    }

    .detail-meta {
        font-size: 13px;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .meta-dot {
        width: 4px;
        height: 4px;
        background: #cbd5e1;
        border-radius: 50%;
    }

    .overdue-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        border-radius: 20px;
        padding: 6px 14px;
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
    }

    .detail-body {
        padding: 26px 28px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    @@media (max-width: 576px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }

    .info-block {
        background: #f8fafc;
        border: 1px solid #f1f5f9;
        border-radius: 10px;
        padding: 14px 16px;
    }

        .info-block.full {
            grid-column: span 2;
        }

    @@media (max-width: 576px) {
        .info-block.full {
            grid-column: span 1;
        }
    }

    .info-key {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #94a3b8;
        margin-bottom: 7px;
    }

    .info-value {
        font-size: 14.5px;
        font-weight: 600;
        color: #0f172a;
    }

        .info-value.muted {
            font-weight: 400;
            color: #64748b;
        }

    .status-pill, .priority-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
    }

        .status-pill::before, .priority-pill::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
        }

    .status-todo {
        background: #f1f5f9;
        color: #475569;
    }

        .status-todo::before {
            background: #94a3b8;
        }

    .status-doing {
        background: #fffbeb;
        color: #92400e;
    }

        .status-doing::before {
            background: #f59e0b;
        }

    .status-done {
        background: #ecfdf5;
        color: #065f46;
    }

        .status-done::before {
            background: #10b981;
        }

    .user-row {
        display: flex;
        align-items: center;
        gap: 9px;
    }

    .user-av {
        width: 30px;
        height: 30px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }

    .description-box {
        white-space: pre-wrap;
        line-height: 1.65;
        color: #334155;
        font-size: 14px;
    }

    .section-divider {
        height: 1px;
        background: #f1f5f9;
        margin: 22px 0;
    }

    .btn-edit {
        background: #fffbeb;
        color: #b45309;
        border: 1px solid #fde68a;
        border-radius: 9px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

        .btn-edit:hover {
            background: #fef3c7;
            color: #92400e;
        }

    .btn-delete {
        background: #fef2f2;
        color: #dc2626;
        border: 1px solid #fecaca;
        border-radius: 9px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

        .btn-delete:hover {
            background: #fee2e2;
        }

    .btn-back {
        background: transparent;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 9px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: all .2s;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

        .btn-back:hover {
            background: #f8fafc;
            border-color: #94a3b8;
            color: #0f172a;
        }
</style>

<div class="detail-wrapper">
    <div class="detail-card">
        <div class="detail-header">
            <div style="flex:1; min-width:0;">
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:8px;">
                    <span style="font-size:12px; color:#94a3b8; font-weight:600;">#@Model.TaskId</span>
                    <span class="status-pill @statusCls">@Model.Status</span>
                    <span class="priority-pill" style="background:@(priorityColor + "18"); color:@priorityColor;">
                        @Model.Priority
                    </span>
                </div>
                <h1 class="detail-title">@Model.Title</h1>
                <div class="detail-meta">
                    <span><i class="bi bi-calendar3 me-1"></i>Tạo ngày @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                    <span class="meta-dot"></span>
                    <span><i class="bi bi-person me-1"></i>@(ViewBag.CreatedUser ?? "Không xác định")</span>
                </div>
            </div>
            @if (isOverdue)
            {
                <div class="overdue-chip">
                    <i class="bi bi-exclamation-triangle-fill"></i> Quá hạn
                </div>
            }
        </div>

        <div class="detail-body">
            <!-- Description -->
            <div class="mb-4">
                <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:#94a3b8; margin-bottom:10px;">Mô tả công việc</div>
                <div class="info-block" style="grid-column:unset;">
                    <div class="description-box">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả" : Model.Description)
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>

            <!-- Info Grid -->
            <div class="info-grid">
                <div class="info-block">
                    <div class="info-key">Hạn hoàn thành</div>
                    <div class="info-value @(isOverdue ? "text-danger" : "")">
                        <i class="bi bi-calendar-event me-1" style="font-size:13px;"></i>
                        @Model.Deadline.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-key">Người được giao</div>
                    <div class="info-value">
                        @if (ViewBag.AssignedUser != null)
                        {
                            <div class="user-row">
                                <div class="user-av">@(((string)ViewBag.AssignedUser).Substring(0, 1).ToUpper())</div>
                                @ViewBag.AssignedUser
                            </div>
                        }
                        else
                        {
                            <span class="muted">Chưa giao</span>
                        }
                    </div>
                </div>

                <div class="info-block">
                    <div class="info-key">Ngày tạo</div>
                    <div class="info-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>

                <div class="info-block">
                    <div class="info-key">Người tạo</div>
                    <div class="info-value">
                        <div class="user-row">
                            <div class="user-av" style="background:linear-gradient(135deg,#10b981,#059669);">
                                @(((string)(ViewBag.CreatedUser ?? "?")).Substring(0, 1).ToUpper())
                            </div>
                            @(ViewBag.CreatedUser ?? "Không xác định")
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>

            <div class="d-flex gap-3 flex-wrap">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.TaskId" class="btn-edit">
                        <i class="bi bi-pencil"></i> Chỉnh sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.TaskId" class="btn-delete">
                        <i class="bi bi-trash"></i> Xóa
                    </a>
                }
                <a asp-action="Index" class="btn-back">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </div>
    </div>
</div>
